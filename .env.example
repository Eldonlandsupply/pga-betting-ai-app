# pga-betting-ai-app environment configuration
# Copy to .env and fill in real values. Never commit .env.

# ── Required ──────────────────────────────────────────────────────────────────
# LLM provider for analysis and pick generation.
# Recommendation is passed as a structured prompt; response is the picks output.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Model to use for pick generation. gpt-4o or gpt-4o-mini recommended.
PGA_CHAT_MODEL=gpt-4o-mini

# ── Optional: data source API keys ────────────────────────────────────────────
# Sports odds API (e.g. The Odds API). Required if using live market ingestion.
ODDS_API_KEY=YOUR_ODDS_API_KEY

# DataGolf API key. Required if using DataGolf for player ratings.
DATAGOLF_API_KEY=YOUR_DATAGOLF_API_KEY

# ── Optional: output / notifications ──────────────────────────────────────────
# Telegram bot token and chat ID for push notifications (optional).
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Optional: tuning ──────────────────────────────────────────────────────────
# Override stale-line threshold (minutes). Default: 30.
PGA_STALE_LINE_MINUTES=30

# Log level: DEBUG, INFO, WARNING, ERROR
PGA_LOG_LEVEL=INFO

# Output directory for generated picks and audit files.
PGA_OUTPUT_DIR=./output
