# pga-betting-ai environment configuration
# Copy to .env and fill in real values. Never commit .env.

# ── Phase 2: Data Sources ─────────────────────────────────────────────────────
# DataGolf API key — for automated player stats and field ingestion
DATAGOLF_API_KEY=YOUR_DATAGOLF_API_KEY

# The Odds API key — for live sportsbook market prices
ODDS_API_KEY=YOUR_ODDS_API_KEY

# ── Optional: Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Optional: Tuning ──────────────────────────────────────────────────────────
# Log level: DEBUG, INFO (default), WARNING, ERROR
PGA_LOG_LEVEL=INFO

# Output directory for picks and audit files
PGA_OUTPUT_DIR=./output
